# Environment Configuration for Redshift E2E Pipeline
# Copy this file to .env and update with your actual values

# S3 Configuration
S3_BUCKET=your-s3-bucket-name

# Redshift Configuration
REDSHIFT_HOST=your-redshift-cluster.region.redshift.amazonaws.com
REDSHIFT_USER=your-username
REDSHIFT_PASSWORD=your-password
REDSHIFT_DATABASE=dev

# IAM Configuration
IAM_ROLE_ARN=arn:aws:iam::your-account:role/RedshiftRole

# Optional: AWS Profile (if not using default)
AWS_PROFILE=default

# Optional: Glue Configuration
GLUE_DATABASE_NAME=your-glue-database
GLUE_JOB_NAME=order-cleanup-job